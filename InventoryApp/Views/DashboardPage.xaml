<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventoryApp.Views.DashboardPage"
             Title="Dashboard">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="30" Spacing="20">

                <Grid HeightRequest="150">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#00FFFF" Offset="0.0"/>
                            <GradientStop Color="#40FF00" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <Image Source="ecci.png"
                           Aspect="AspectFit"
                           HeightRequest="150"/>
                </Grid>

                <Label Text="Gestor de Inventario"
                       FontSize="28"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>

                <Label Text="Selecciona una opción para continuar"
                       FontSize="14"
                       HorizontalOptions="Center"
                       TextColor="Gray"/>

                <Button Text="📦  Gestionar Productos"
                        Command="{Binding GoProductsCommand}"
                        HeightRequest="55"
                        FontSize="16"/>

                <Button Text="🏭  Ver Proveedores"
                        Command="{Binding GoProveedoresCommand}"
                        HeightRequest="55"
                        FontSize="16"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Footer -->
        <Grid Grid.Row="1"
              BackgroundColor="#191919"
              Padding="10"
              ColumnDefinitions="*,*,*,*">

            <Button Grid.Column="0"
                    Text="Inicio"
                    BackgroundColor="Transparent"
                    TextColor="#00FFFF"
                    Command="{Binding GoInicioCommand}"/>

            <Button Grid.Column="1"
                    Text="Productos"
                    BackgroundColor="Transparent"
                    TextColor="#FF10F0"
                    Command="{Binding GoProductsCommand}"/>

            <Button Grid.Column="2"
                    Text="Proveedores"
                    BackgroundColor="Transparent"
                    TextColor="#FFA500"
                    Command="{Binding GoProveedoresCommand}"/>

            <Button Grid.Column="3"
                    Text="Perfil"
                    BackgroundColor="Transparent"
                    TextColor="#39FF14"/>

        </Grid>

    </Grid>

</ContentPage>
