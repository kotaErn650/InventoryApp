<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventoryApp.Views.ProductFormPage"
             Title="{Binding Title}">
    <ScrollView>

        <VerticalStackLayout Padding="20" Spacing="12">

            <Label Text="Nombre" FontAttributes="Bold"/>
            <Entry Placeholder="Nombre del producto"
                   Text="{Binding Nombre}"/>

            <Label Text="Descripción" FontAttributes="Bold"/>
            <Editor Placeholder="Descripción del producto"
                    HeightRequest="100"
                    Text="{Binding Descripcion}"/>

            <Label Text="Precio" FontAttributes="Bold"/>
            <Entry Placeholder="0.00"
                   Keyboard="Numeric"
                   Text="{Binding Precio}"/>

            <Label Text="Stock" FontAttributes="Bold"/>
            <Entry Placeholder="0"
                   Keyboard="Numeric"
                   Text="{Binding Stock}"/>

            <Label Text="Estado" FontAttributes="Bold"/>
            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                <Label Grid.Column="0"
                       Text="{Binding Activo, Converter={StaticResource BoolToEstadoConverter}}"
                       VerticalOptions="Center"
                       FontSize="14"/>
                <Switch Grid.Column="1"
                        IsToggled="{Binding Activo}"
                        VerticalOptions="Center"/>
            </Grid>

            <Button Text="💾  Guardar"
                    Command="{Binding SaveCommand}"
                    HeightRequest="50"
                    Margin="0,10,0,0"/>

        </VerticalStackLayout>

    </ScrollView>
</ContentPage>
