<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventoryApp.Views.ProveedoresPage"
             Title="Proveedores">

    <Grid RowDefinitions="Auto,*">

        <Button Grid.Row="0"
                Text="+ Nuevo Proveedor"
                Command="{Binding NewCommand}"
                Margin="15,10"/>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Proveedores}"
                        Margin="10,0">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,5" Padding="12" StrokeShape="RoundRectangle 8">

                        <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="80,*">

                            <Image Grid.Row="0" Grid.Column="0" Grid.RowSpan="3"
                                   Source="{Binding Foto}"
                                   WidthRequest="70"
                                   HeightRequest="70"
                                   Aspect="AspectFill"
                                   VerticalOptions="Center">
                                <Image.Clip>
                                    <EllipseGeometry Center="35,35" RadiusX="35" RadiusY="35"/>
                                </Image.Clip>
                            </Image>

                            <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="3" Padding="12,0,0,0">

                                <Label Text="{Binding Nombre}"
                                       FontSize="17"
                                       FontAttributes="Bold"/>

                                <Label Text="{Binding TipoProducto, StringFormat='Tipo: {0}'}"
                                       FontSize="13"
                                       TextColor="Gray"/>

                                <Label Text="{Binding Activo, Converter={StaticResource BoolToEstadoConverter}}"
                                       FontAttributes="Bold"
                                       FontSize="13"/>

                            </VerticalStackLayout>

                            <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                  ColumnDefinitions="*,Auto,Auto"
                                  Margin="0,8,0,0">

                                <Label Grid.Column="0"
                                       Text="{Binding Telefono, StringFormat='📞 {0}'}"
                                       FontSize="12"
                                       TextColor="Gray"
                                       VerticalOptions="Center"/>

                                <Button Grid.Column="1"
                                        Text="Editar"
                                        FontSize="12"
                                        HeightRequest="36"
                                        Padding="10,0"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditCommand}"
                                        CommandParameter="{Binding .}"/>

                                <Button Grid.Column="2"
                                        Text="{Binding Activo, Converter={StaticResource BoolToToggleTextConverter}}"
                                        BackgroundColor="{Binding Activo, Converter={StaticResource BoolToToggleColorConverter}}"
                                        FontSize="12"
                                        HeightRequest="36"
                                        Padding="10,0"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ToggleActivoCommand}"
                                        CommandParameter="{Binding .}"/>

                            </Grid>

                        </Grid>

                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>

</ContentPage>
