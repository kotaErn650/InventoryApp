<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventoryApp.Views.ProveedoresPage"
             Title="Proveedores">

    <CollectionView ItemsSource="{Binding Proveedores}"
                    Margin="10,10">

        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border Margin="0,5" Padding="12" StrokeShape="RoundRectangle 8">

                    <Grid ColumnDefinitions="80,*" ColumnSpacing="12">

                        <Image Grid.Column="0"
                               Source="{Binding Foto}"
                               WidthRequest="70"
                               HeightRequest="70"
                               Aspect="AspectFill">
                            <Image.Clip>
                                <EllipseGeometry Center="35,35" RadiusX="35" RadiusY="35"/>
                            </Image.Clip>
                        </Image>

                        <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">

                            <Label Text="{Binding Nombre}"
                                   FontSize="17"
                                   FontAttributes="Bold"/>

                            <Label Text="{Binding TipoProducto, StringFormat='Tipo: {0}'}"
                                   FontSize="13"
                                   TextColor="Gray"/>

                        </VerticalStackLayout>

                    </Grid>

                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>

    </CollectionView>

</ContentPage>
