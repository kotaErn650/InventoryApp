<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventoryApp.Views.ProveedorFormPage"
             Title="{Binding Title}">
    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">

            <VerticalStackLayout Padding="20" Spacing="12">

                <Label Text="Nombre" FontAttributes="Bold"/>
                <Entry Placeholder="Nombre del proveedor"
                       Text="{Binding Nombre}"/>

                <Label Text="Tipo de Producto" FontAttributes="Bold"/>
                <Entry Placeholder="Ej. Electrónica, Papelería..."
                       Text="{Binding TipoProducto}"/>

                <Label Text="Teléfono" FontAttributes="Bold"/>
                <Entry Placeholder="Número de contacto"
                       Keyboard="Telephone"
                       Text="{Binding Telefono}"/>

                <Label Text="Correo Electrónico" FontAttributes="Bold"/>
                <Entry Placeholder="correo@ejemplo.com"
                       Keyboard="Email"
                       Text="{Binding Email}"/>

                <Label Text="Estado" FontAttributes="Bold"/>
                <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                    <Label Grid.Column="0"
                           Text="{Binding Activo, Converter={StaticResource BoolToEstadoConverter}}"
                           VerticalOptions="Center"
                           FontSize="14"/>
                    <Switch Grid.Column="1"
                            IsToggled="{Binding Activo}"
                            VerticalOptions="Center"/>
                </Grid>

                <Button Text="💾  Guardar"
                        Command="{Binding SaveCommand}"
                        HeightRequest="50"
                        Margin="0,10,0,0"/>

            </VerticalStackLayout>

        </ScrollView>

        <!-- Footer -->
        <Grid Grid.Row="1"
              BackgroundColor="#191919"
              Padding="10"
              ColumnDefinitions="*,*,*,*">

            <Button Grid.Column="0"
                    Text="Inicio"
                    BackgroundColor="Transparent"
                    TextColor="#00FFFF"
                    Command="{Binding GoInicioCommand}"/>

            <Button Grid.Column="1"
                    Text="Productos"
                    BackgroundColor="Transparent"
                    TextColor="#FF10F0"
                    Command="{Binding GoProductsCommand}"/>

            <Button Grid.Column="2"
                    Text="Proveedores"
                    BackgroundColor="Transparent"
                    TextColor="#FFA500"
                    Command="{Binding GoProveedoresCommand}"/>

            <Button Grid.Column="3"
                    Text="Perfil"
                    BackgroundColor="Transparent"
                    TextColor="#39FF14"/>

        </Grid>

    </Grid>
</ContentPage>
