<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventoryApp.Views.ProductsPage"
             Title="Productos">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Botón arriba -->
        <Button Grid.Row="0"
                Text="+ Nuevo Producto"
                Command="{Binding NewCommand}"
                Margin="15,10"/>

        <!-- Lista -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Products}"
                        Margin="10,0">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,5" Padding="12" StrokeShape="RoundRectangle 8">

                        <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto,Auto">

                            <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                                   Text="{Binding Nombre}"
                                   FontSize="18"
                                   FontAttributes="Bold"/>

                            <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                   Text="{Binding Descripcion}"
                                   FontSize="13"
                                   TextColor="Gray"/>

                            <Label Grid.Row="2" Grid.Column="0"
                                   Text="{Binding Precio, StringFormat='Precio: ${0:N2}'}"
                                   FontSize="14"/>

                            <Label Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                   Text="{Binding Stock, StringFormat='Stock: {0}'}"
                                   FontSize="14"
                                   HorizontalOptions="End"/>

                            <Label Grid.Row="3" Grid.Column="0"
                                   Text="{Binding Activo, Converter={StaticResource BoolToEstadoConverter}}"
                                   FontAttributes="Bold"
                                   FontSize="13"/>

                            <Button Grid.Row="3" Grid.Column="1"
                                    Text="Editar"
                                    FontSize="12"
                                    HeightRequest="36"
                                    Padding="10,0"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditCommand}"
                                    CommandParameter="{Binding .}"/>

                            <Button Grid.Row="3" Grid.Column="2"
                                    Text="Deshabilitar"
                                    FontSize="12"
                                    HeightRequest="36"
                                    Padding="10,0"
                                    BackgroundColor="#CC3333"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DisableCommand}"
                                    CommandParameter="{Binding .}"/>

                        </Grid>

                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <!-- Footer -->
        <Grid Grid.Row="2"
              BackgroundColor="#191919"
              Padding="10"
              ColumnDefinitions="*,*,*,*">

            <Button Grid.Column="0"
                    Text="Inicio"
                    BackgroundColor="Transparent"
                    TextColor="#00FFFF"
                    Command="{Binding GoInicioCommand}"/>

            <Button Grid.Column="1"
                    Text="Productos"
                    BackgroundColor="Transparent"
                    TextColor="#FF10F0"
                    Command="{Binding GoProductsCommand}"/>

            <Button Grid.Column="2"
                    Text="Proveedores"
                    BackgroundColor="Transparent"
                    TextColor="#FFA500"
                    Command="{Binding GoProveedoresCommand}"/>

            <Button Grid.Column="3"
                    Text="Perfil"
                    BackgroundColor="Transparent"
                    TextColor="#39FF14"/>

        </Grid>

    </Grid>

</ContentPage>