<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:InventoryApp"
             xmlns:converters="clr-namespace:InventoryApp.Converters"
             x:Class="InventoryApp.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:BoolToEstadoConverter x:Key="BoolToEstadoConverter"/>
            <converters:BoolToToggleTextConverter x:Key="BoolToToggleTextConverter"/>
            <converters:BoolToToggleColorConverter x:Key="BoolToToggleColorConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
